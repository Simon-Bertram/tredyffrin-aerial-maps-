{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "wrangler dev src/index.ts --config wrangler.toml --port 3000",
    "test": "vitest run"
  },
  "dependencies": {
    "@sanity/client": "^7.21.0",
    "@tehs-aerial-images/db": "workspace:*",
    "@tehs-aerial-images/env": "workspace:*",
    "@tehs-aerial-images/shared": "workspace:*",
    "dotenv": "catalog:",
    "hono": "^4.8.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@tehs-aerial-images/config": "workspace:*",
    "@types/node": "catalog:",
    "alchemy": "catalog:",
    "tsdown": "^0.16.5",
    "typescript": "catalog:",
    "wrangler": "^4.77.0"
  }
}
