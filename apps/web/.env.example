# Copy to .env and fill in as needed.

# EmDash passkeys: set to the exact admin origin you use in the browser (scheme + host + port).
# If this is wrong or unset while the browser uses another host (127.0.0.1 vs localhost, forwarded URL),
# WebAuthn can fail with errors that look like network failures.
# PUBLIC_PASSKEY_ORIGIN=http://localhost:4321

# Optional: Cloudflare Access for EmDash admin (disables passkey-only auth when set).
# CF_ACCESS_TEAM_DOMAIN=yourteam.cloudflareaccess.com
# CF_ACCESS_AUDIENCE=<audience tag from Access application>

# Optional: Cloudflare Images + Stream (media library features).
# CF_MEDIA_ACCOUNT_ID=
# CF_MEDIA_API_TOKEN=
# CF_IMAGES_ACCOUNT_HASH=

# EmDash sandboxed plugins require Cloudflare Dynamic Workers (paid Workers plan).
