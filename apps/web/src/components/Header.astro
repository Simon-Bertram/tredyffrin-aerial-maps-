---
const links = [{ to: "/", label: "Home" }];
---

<div class="bg-surface-container-low">
  <div class="flex flex-row items-center justify-between px-4 py-3 md:px-6">
    <nav class="flex gap-6 text-sm tracking-[0.1em] uppercase">
      {
        links.map((link) => (
          <a
            href={link.to}
            class="text-secondary hover:text-primary transition-colors"
          >
            {link.label}
          </a>
        ))
      }
    </nav>
    <div class="flex items-center gap-2" id="user-menu-container"></div>
  </div>
</div>
