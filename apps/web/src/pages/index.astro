---
import Layout from "../layouts/Layout.astro";
import { AerialMap } from "@/components/aerial-map";
import { getSanityLocationRecordsList } from "@/lib/sanity-location-repository";
import { env } from "@tehs-aerial-images/env/web";

const locations = await getSanityLocationRecordsList();
const backendStatusResponse = await fetch(`${env.PUBLIC_SERVER_URL}/`);
const backendStatus = backendStatusResponse.ok
  ? await backendStatusResponse.text()
  : "UNAVAILABLE";
---

<Layout title="tredyffrin-aerial-images">
  <main class="min-h-screen bg-surface py-10">
    <div class="container mx-auto px-4 md:px-8">
      <section class="bg-surface-container-low p-6 md:p-10">
        <p class="text-secondary mb-4 text-xs tracking-widest uppercase">
          Digital Archive
        </p>
        <h1 class="text-primary mb-6 text-4xl md:text-5xl">
          Welcome to The Tredyffrin Aerial Images Collection
        </h1>
        <p class="text-muted-foreground mb-8 max-w-2xl text-sm md:text-base">
          Explore historical aerial photography curated as a living regional
          archive with rich map detail and contextual metadata.
        </p>
        <p data-testid="backend-status" class="mb-4 text-sm text-muted-foreground">
          Backend status: {backendStatus}
        </p>
        <AerialMap client:load locations={locations} />
      </section>
    </div>
  </main>
</Layout>
