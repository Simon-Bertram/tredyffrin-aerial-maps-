---
import Layout from "../../layouts/Layout.astro";
import { PortableText } from "astro-portabletext";
import { getEmDashEntry } from "emdash";

const slug = Astro.params.slug;
if (!slug) {
	return Astro.redirect("/blog");
}

const { entry, error } = await getEmDashEntry("posts", slug);
if (error) {
	throw error;
}
if (!entry) {
	return Astro.redirect("/404");
}

const data = entry.data;
const title = String(data.title ?? "Post");
const blocks = data.content;
---

<Layout title={title}>
	<article class="container mx-auto max-w-3xl px-4 py-8 text-white">
		<a class="text-sm text-sky-400 hover:underline" href="/blog">← Blog</a>
		<h1 class="mt-4 text-3xl font-semibold">{title}</h1>
		<div class="prose prose-invert mt-6 max-w-none">
			{Array.isArray(blocks) && blocks.length > 0 ? (
				<PortableText value={blocks} />
			) : (
				<p class="text-neutral-400">No content.</p>
			)}
		</div>
	</article>
</Layout>
