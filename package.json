{
  "name": "tehs-aerial-images",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "dev:web": "turbo run -F web dev",
    "dev:server": "turbo run -F server dev",
    "db:push": "turbo run -F @tehs-aerial-images/db db:push",
    "db:generate": "turbo run -F @tehs-aerial-images/db db:generate",
    "deploy": "turbo run -F @tehs-aerial-images/infra deploy",
    "destroy": "turbo run -F @tehs-aerial-images/infra destroy"
  },
  "dependencies": {
    "@tehs-aerial-images/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.7",
    "@cloudflare/workers-types": "catalog:",
    "@tehs-aerial-images/config": "workspace:*",
    "@types/node": "catalog:",
    "turbo": "^2.9.6",
    "typescript": "catalog:",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@10.32.1"
}
